# =============================================================================
# EDURA SaaS — Variables de entorno
# Copiar este archivo a .env y completar los valores
# .env NUNCA debe subirse al repositorio (está en .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Entorno de ejecución
# Valores: desarrollo | pruebas | produccion | test
# -----------------------------------------------------------------------------
ENTORNO=desarrollo

# -----------------------------------------------------------------------------
# Servidor HTTP
# -----------------------------------------------------------------------------
PUERTO_API=3000

# Orígenes permitidos para CORS (separados por coma)
ORIGENES_CORS=http://localhost:5173

# -----------------------------------------------------------------------------
# Base de datos PostgreSQL
# -----------------------------------------------------------------------------
BD_HOST=localhost
BD_PUERTO=5432
BD_USUARIO=postgres
BD_CLAVE=cambia_esta_clave
BD_NOMBRE=edura
BD_SSL=false

# Registrar queries SQL en consola (solo para depuración local)
BD_REGISTRO_CONSULTAS=false

# -----------------------------------------------------------------------------
# Autenticación JWT
# En producción: mínimo 32 caracteres aleatorios (usa: openssl rand -hex 32)
# -----------------------------------------------------------------------------
JWT_SECRETO=dev-secret-minimo-32-caracteres-cambiar-en-produccion
JWT_EMISOR=EDURA
JWT_AUDIENCIA=EDURA_WEB

# Tiempo de vida del access token (segundos). Defecto: 900 (15 min)
JWT_ACCESO_TTL_SEGUNDOS=900

# Tiempo de vida del refresh token (segundos). Defecto: 2592000 (30 días)
TOKEN_REFRESH_TTL_SEGUNDOS=2592000

# Secreto para hash de refresh tokens opacos (mínimo 32 caracteres)
HASH_TOKEN_SECRETO=dev-hash-secret-minimo-32-caracteres-cambiar-en-produccion

# -----------------------------------------------------------------------------
# Semilla — Bootstrap de administrador de plataforma
# Solo se usa al ejecutar: npm run db:seed:bootstrap
# El usuario se crea una sola vez (idempotente). La clave NO se registra en logs.
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_CORREO=admin@edura.local
BOOTSTRAP_ADMIN_CLAVE=CambiaMeAhora2024!
BOOTSTRAP_ADMIN_NOMBRE=Administrador EDURA

# -----------------------------------------------------------------------------
# Integración externa — Documentos de identidad (APIsPeru)
# Documentación: https://apisperu.com
# Dejar INTEGRACION_DOCUMENTOS_HABILITADA=false si no se tiene token
# -----------------------------------------------------------------------------
INTEGRACION_DOCUMENTOS_HABILITADA=false
PROVEEDOR_DOCUMENTOS=APISPERU
APISPERU_URL_BASE=https://dniruc.apisperu.com/api/v1
APISPERU_TOKEN=
APISPERU_TIMEOUT_MS=3000

# -----------------------------------------------------------------------------
# Integración externa — Cálculo de rutas (Google Maps)
# Requiere API key con Distance Matrix habilitada
# Dejar INTEGRACION_RUTAS_HABILITADA=false si no se tiene API key
# -----------------------------------------------------------------------------
INTEGRACION_RUTAS_HABILITADA=false
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_TIMEOUT_MS=4000
