{
  "name": "back",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24",
    "npm": ">=10"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "test": "jest --config ./test/jest-unit.json",
    "test:unit": "jest --config ./test/jest-unit.json --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --config ./test/jest-unit.json --coverage --runInBand",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "db:migration:create": "typeorm-ts-node-commonjs migration:create src/base-datos/typeorm/migraciones/$npm_config_name",
    "db:migration:generate": "typeorm-ts-node-commonjs migration:generate src/base-datos/typeorm/migraciones/$npm_config_name -d src/base-datos/typeorm/fuente-datos.ts",
    "db:migration:run": "typeorm-ts-node-commonjs migration:run -d src/base-datos/typeorm/fuente-datos.ts",
    "db:migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/base-datos/typeorm/fuente-datos.ts",
    "db:migration:show": "typeorm-ts-node-commonjs migration:show -d src/base-datos/typeorm/fuente-datos.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/base-datos/typeorm/semillas/sembrar.ts",
    "db:seed:catalogos": "ts-node -r tsconfig-paths/register src/base-datos/typeorm/semillas/sembrar.ts catalogos",
    "db:seed:seguridad": "ts-node -r tsconfig-paths/register src/base-datos/typeorm/semillas/sembrar.ts seguridad",
    "db:seed:bootstrap": "ts-node -r tsconfig-paths/register src/base-datos/typeorm/semillas/bootstrap-admin.ts",
    "db:seed:demo": "ts-node -r tsconfig-paths/register src/base-datos/typeorm/semillas/demo.ts",
    "db:seed:all": "ts-node -r tsconfig-paths/register src/base-datos/typeorm/semillas/sembrar-todo.ts",
    "db:reseed:local": "ts-node -r tsconfig-paths/register src/base-datos/typeorm/semillas/reiniciar-local.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.2.0",
    "joi": "^17.13.3",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".+\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      ".e2e-spec.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
