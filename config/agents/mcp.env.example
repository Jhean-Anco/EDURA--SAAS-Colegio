# Variables de entorno para servidores MCP de EDURA
# NUNCA versionar con valores reales.
# Configurar en el entorno del sistema o en un .env.local no versionado.
#
# Para cada variable se indica: servidor que la consume, si es requerida u opcional,
# y el alcance mínimo requerido.

# ── PostgreSQL MCP ───────────────────────────────────────────────────────────
# Servidor: postgres-local-readonly
# Requerida: sí (para perfil database-review)
# Formato: postgresql://<usuario_readonly>:<clave>@<host>:<puerto>/<base>
# Alcance mínimo: CONNECT + SELECT en esquemas de EDURA. Sin INSERT/UPDATE/DELETE/DDL.
# IMPORTANTE: Usar una cuenta de solo lectura dedicada, no BD_USUARIO del .env principal.
POSTGRES_MCP_URL=postgresql://edura_readonly:<clave>@localhost:5432/edura_dev

# ── GitHub MCP ───────────────────────────────────────────────────────────────
# Servidor: github (Codex plugin o MCP separado)
# Requerida: sí (para perfil pr-review)
# Fuente: https://github.com/settings/tokens/new
# Alcance mínimo: repo (solo lectura al repositorio EDURA), sin administración.
# Para operaciones de escritura (PR, comentarios): añadir write:discussion.
# Restricción recomendada: token de acceso fino al repo EDURA únicamente.
GITHUB_TOKEN=ghp_<token_de_acceso_fino>

# ── Google Cloud / NotebookLM Enterprise ────────────────────────────────────
# Servidor: notebooklm-enterprise (cuando esté disponible)
# Requerida: solo si se usa NotebookLM Enterprise
# Opción A — Application Default Credentials (recomendada):
#   Ejecutar: gcloud auth application-default login
#   No se requiere variable adicional cuando ADC está configurado.
# Opción B — Service Account:
#   GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/service-account.json
# Opción C — Proyecto explícito:
GOOGLE_CLOUD_PROJECT=<id-proyecto-google-cloud>
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/service-account.json

# ── Stitch ────────────────────────────────────────────────────────────────────
# Servidor: stitch (perfil frontend-ui, solo cuando tarea implique diseño UX)
# Requerida: sí (para usar Stitch MCP)
# Fuente: Stitch dashboard → API Keys
# Alcance mínimo: lectura de proyectos autorizados únicamente.
STITCH_API_KEY=<api_key_restringida_a_proyecto_edura>

# ── Instrucciones de uso ─────────────────────────────────────────────────────
# Windows PowerShell (sesión actual):
#   $env:POSTGRES_MCP_URL = "postgresql://..."
#   $env:GITHUB_TOKEN = "ghp_..."
#
# Windows — variable de sistema permanente (sin mostrar en terminal):
#   [System.Environment]::SetEnvironmentVariable("POSTGRES_MCP_URL", "...", "User")
#
# .env.local (no versionado, cargado por scripts de plataforma):
#   Copiar este archivo como .env.local y completar los valores.
#   Asegurarse de que .env.local esté en .gitignore.
